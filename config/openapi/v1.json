{
  "openapi": "3.1.0",
  "info": {
    "title": "sqlbook API",
    "version": "v1",
    "description": "Workspace and team management API used by chat runtime and app surfaces.\n\nThis API is session-authenticated, strictly workspace-scoped, and server-authoritative: every request is checked against the current user, the current workspace, and the same role/scope rules used by the product UI and chat runtime.\n\nFor LLM and tool consumers, treat each operation as an executable contract. Do not infer permissions from docs alone: always rely on response status and error_code. Mutating actions may still be blocked by role or workspace scope even when the payload is structurally valid."
  },
  "servers": [
    {
      "url": "/",
      "description": "Current sqlbook app origin"
    }
  ],
  "security": [
    {
      "cookieAuth": []
    }
  ],
  "tags": [
    {
      "name": "Workspace",
      "description": "Operations that modify the current workspace itself. These stay in the active workspace only and never cross workspace boundaries.",
      "x-displayName": "Workspace"
    },
    {
      "name": "Members",
      "description": "Operations for listing, inviting, updating, and removing workspace members. These mirror the team-management surface in the app.",
      "x-displayName": "Members"
    },
    {
      "name": "Data Sources",
      "description": "Operations for listing, validating, and creating workspace data sources. In this phase the documented connector flow is PostgreSQL-only and remains workspace-scoped and session-authenticated.",
      "x-displayName": "Data Sources"
    }
  ],
  "x-tagGroups": [
    {
      "name": "Workspace management",
      "tags": ["Workspace"]
    },
    {
      "name": "Team management",
      "tags": ["Members"]
    },
    {
      "name": "Data connectivity",
      "tags": ["Data Sources"]
    }
  ],
  "x-scalar-active-environment": "current-origin",
  "x-scalar-environments": {
    "current-origin": {
      "description": "Use the current sqlbook environment origin and example resource ids.",
      "variables": {
        "apiUrl": {
          "description": "Base URL for the current environment.",
          "default": "/"
        },
        "workspaceId": {
          "description": "Example workspace id used in code samples.",
          "default": "7"
        },
        "memberId": {
          "description": "Example workspace member id used in code samples.",
          "default": "27"
        }
      }
    }
  },
  "paths": {
    "/api/v1/workspaces/{workspace_id}": {
      "patch": {
        "operationId": "workspaceUpdateName",
        "summary": "Rename workspace",
        "description": "Renames the current workspace. This is a low-risk write in chat, but API callers should still expect server-side permission checks. The new name should be sent as a clean target value without surrounding conversational punctuation.",
        "tags": ["Workspace"],
        "parameters": [
          {
            "$ref": "#/components/parameters/workspaceId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WorkspaceRenameRequest"
              },
              "examples": {
                "renameWorkspace": {
                  "summary": "Rename the workspace",
                  "value": {
                    "name": "Bumanarama"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/WorkspaceRenamed"
          },
          "401": {
            "$ref": "#/components/responses/ToolUnauthorized"
          },
          "403": {
            "$ref": "#/components/responses/ToolForbidden"
          },
          "422": {
            "$ref": "#/components/responses/ToolValidationError"
          },
          "500": {
            "$ref": "#/components/responses/ToolExecutionError"
          }
        },
        "x-codeSamples": [
          {
            "lang": "Shell",
            "label": "curl",
            "source": "curl -X PATCH '{{apiUrl}}api/v1/workspaces/{{workspaceId}}' \\\n  -H 'Content-Type: application/json' \\\n  -H 'Cookie: _sqlbook_session=<session-cookie>' \\\n  --data '{\"name\":\"Bumanarama\"}'"
          }
        ]
      },
      "delete": {
        "operationId": "workspaceDelete",
        "summary": "Delete workspace",
        "description": "Deletes the current workspace. This is a destructive operation and is owner-only. Successful responses may include a redirect path for product surfaces that should return to the workspace index.",
        "tags": ["Workspace"],
        "parameters": [
          {
            "$ref": "#/components/parameters/workspaceId"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/WorkspaceDeleted"
          },
          "401": {
            "$ref": "#/components/responses/ToolUnauthorized"
          },
          "403": {
            "$ref": "#/components/responses/ToolForbidden"
          },
          "422": {
            "$ref": "#/components/responses/ToolValidationError"
          },
          "500": {
            "$ref": "#/components/responses/ToolExecutionError"
          }
        },
        "x-codeSamples": [
          {
            "lang": "Shell",
            "label": "curl",
            "source": "curl -X DELETE '{{apiUrl}}api/v1/workspaces/{{workspaceId}}' \\\n  -H 'Cookie: _sqlbook_session=<session-cookie>'"
          }
        ]
      }
    },
    "/api/v1/workspaces/{workspace_id}/members": {
      "get": {
        "operationId": "memberList",
        "summary": "List members",
        "description": "Returns detailed member data for the current workspace. Consumers should expect names, emails, role labels, role ids, and status labels in the response payload.",
        "tags": ["Members"],
        "parameters": [
          {
            "$ref": "#/components/parameters/workspaceId"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/MembersListed"
          },
          "401": {
            "$ref": "#/components/responses/ToolUnauthorized"
          },
          "403": {
            "$ref": "#/components/responses/ToolForbidden"
          },
          "500": {
            "$ref": "#/components/responses/ToolExecutionError"
          }
        },
        "x-codeSamples": [
          {
            "lang": "Shell",
            "label": "curl",
            "source": "curl '{{apiUrl}}api/v1/workspaces/{{workspaceId}}/members' \\\n  -H 'Cookie: _sqlbook_session=<session-cookie>'"
          }
        ]
      },
      "post": {
        "operationId": "memberInvite",
        "summary": "Invite member",
        "description": "Invites a new member into the current workspace. `first_name`, `last_name`, `email`, and `role` are all required.",
        "tags": ["Members"],
        "parameters": [
          {
            "$ref": "#/components/parameters/workspaceId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MemberInviteRequest"
              },
              "examples": {
                "inviteUser": {
                  "summary": "Invite a user",
                  "value": {
                    "first_name": "Bob",
                    "last_name": "Jenkins",
                    "email": "hello@sqlbook.com",
                    "role": 3
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/MemberInvited"
          },
          "401": {
            "$ref": "#/components/responses/ToolUnauthorized"
          },
          "403": {
            "$ref": "#/components/responses/ToolForbidden"
          },
          "422": {
            "$ref": "#/components/responses/ToolValidationError"
          },
          "500": {
            "$ref": "#/components/responses/ToolExecutionError"
          }
        },
        "x-codeSamples": [
          {
            "lang": "Shell",
            "label": "curl",
            "source": "curl -X POST '{{apiUrl}}api/v1/workspaces/{{workspaceId}}/members' \\\n  -H 'Content-Type: application/json' \\\n  -H 'Cookie: _sqlbook_session=<session-cookie>' \\\n  --data '{\"first_name\":\"Bob\",\"last_name\":\"Jenkins\",\"email\":\"hello@sqlbook.com\",\"role\":3}'"
          }
        ]
      }
    },
    "/api/v1/workspaces/{workspace_id}/members/resend-invite": {
      "post": {
        "operationId": "memberResendInvite",
        "summary": "Resend invite",
        "description": "Resends a pending invitation. Provide either `member_id` or `email`. Only pending invitations can be resent, and resend cooldown rules are enforced server-side.",
        "tags": ["Members"],
        "parameters": [
          {
            "$ref": "#/components/parameters/workspaceId"
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MemberResendInviteRequest"
              },
              "examples": {
                "byEmail": {
                  "summary": "Resend by email",
                  "value": {
                    "email": "hello@sqlbook.com"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/MemberInviteResent"
          },
          "401": {
            "$ref": "#/components/responses/ToolUnauthorized"
          },
          "403": {
            "$ref": "#/components/responses/ToolForbidden"
          },
          "422": {
            "$ref": "#/components/responses/ToolValidationError"
          },
          "500": {
            "$ref": "#/components/responses/ToolExecutionError"
          }
        },
        "x-codeSamples": [
          {
            "lang": "Shell",
            "label": "curl",
            "source": "curl -X POST '{{apiUrl}}api/v1/workspaces/{{workspaceId}}/members/resend-invite' \\\n  -H 'Content-Type: application/json' \\\n  -H 'Cookie: _sqlbook_session=<session-cookie>' \\\n  --data '{\"email\":\"hello@sqlbook.com\"}'"
          }
        ]
      }
    },
    "/api/v1/workspaces/{workspace_id}/members/{id}/role": {
      "patch": {
        "operationId": "memberUpdateRole",
        "summary": "Update role",
        "description": "Updates the role for an existing workspace member. This is a high-risk write in chat and remains server-authorized here as well. Role values must be one of the editable non-owner roles allowed by policy.",
        "tags": ["Members"],
        "parameters": [
          {
            "$ref": "#/components/parameters/workspaceId"
          },
          {
            "$ref": "#/components/parameters/memberId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MemberUpdateRoleRequest"
              },
              "examples": {
                "promoteToAdmin": {
                  "summary": "Promote member to admin",
                  "value": {
                    "role": 2
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/MemberRoleUpdated"
          },
          "401": {
            "$ref": "#/components/responses/ToolUnauthorized"
          },
          "403": {
            "$ref": "#/components/responses/ToolForbidden"
          },
          "422": {
            "$ref": "#/components/responses/ToolValidationError"
          },
          "500": {
            "$ref": "#/components/responses/ToolExecutionError"
          }
        },
        "x-codeSamples": [
          {
            "lang": "Shell",
            "label": "curl",
            "source": "curl -X PATCH '{{apiUrl}}api/v1/workspaces/{{workspaceId}}/members/{{memberId}}/role' \\\n  -H 'Content-Type: application/json' \\\n  -H 'Cookie: _sqlbook_session=<session-cookie>' \\\n  --data '{\"role\":2}'"
          }
        ]
      }
    },
    "/api/v1/workspaces/{workspace_id}/members/{id}": {
      "delete": {
        "operationId": "memberRemove",
        "summary": "Remove member",
        "description": "Removes a workspace member. Owners cannot be removed. Accepted members may trigger downstream notification side effects after removal.",
        "tags": ["Members"],
        "parameters": [
          {
            "$ref": "#/components/parameters/workspaceId"
          },
          {
            "$ref": "#/components/parameters/memberId"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/MemberRemoved"
          },
          "401": {
            "$ref": "#/components/responses/ToolUnauthorized"
          },
          "403": {
            "$ref": "#/components/responses/ToolForbidden"
          },
          "422": {
            "$ref": "#/components/responses/ToolValidationError"
          },
          "500": {
            "$ref": "#/components/responses/ToolExecutionError"
          }
        },
        "x-codeSamples": [
          {
            "lang": "Shell",
            "label": "curl",
            "source": "curl -X DELETE '{{apiUrl}}api/v1/workspaces/{{workspaceId}}/members/{{memberId}}' \\\n  -H 'Cookie: _sqlbook_session=<session-cookie>'"
          }
        ]
      }
    },
    "/api/v1/workspaces/{workspace_id}/data-sources": {
      "get": {
        "operationId": "dataSourceList",
        "summary": "List data sources",
        "description": "Returns the data sources attached to the current workspace. The payload is safe to consume directly in chat or UI code because it is already scoped to the current workspace and includes connector type, lifecycle status, selected table counts, and related query counts.",
        "tags": ["Data Sources"],
        "parameters": [
          {
            "$ref": "#/components/parameters/workspaceId"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/DataSourcesListed"
          },
          "401": {
            "$ref": "#/components/responses/ToolUnauthorized"
          },
          "403": {
            "$ref": "#/components/responses/ToolForbidden"
          },
          "500": {
            "$ref": "#/components/responses/ToolExecutionError"
          }
        },
        "x-codeSamples": [
          {
            "lang": "Shell",
            "label": "curl",
            "source": "curl '{{apiUrl}}api/v1/workspaces/{{workspaceId}}/data-sources' \\\n  -H 'Cookie: _sqlbook_session=<session-cookie>'"
          }
        ]
      },
      "post": {
        "operationId": "dataSourceCreate",
        "summary": "Create PostgreSQL data source",
        "description": "Creates a PostgreSQL data source after validating the connection details and selected tables. This endpoint is workspace-scoped, session-authenticated, and owner/admin-only.",
        "tags": ["Data Sources"],
        "parameters": [
          {
            "$ref": "#/components/parameters/workspaceId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DataSourceCreateRequest"
              },
              "examples": {
                "postgresCreate": {
                  "summary": "Create a PostgreSQL source",
                  "value": {
                    "name": "Ecomm Warehouse",
                    "host": "db.example.com",
                    "port": 5432,
                    "database_name": "sales",
                    "username": "sqlbook",
                    "password": "secret",
                    "ssl_mode": "prefer",
                    "selected_tables": ["public.orders", "public.customers"]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/DataSourceCreated"
          },
          "401": {
            "$ref": "#/components/responses/ToolUnauthorized"
          },
          "403": {
            "$ref": "#/components/responses/ToolForbidden"
          },
          "422": {
            "$ref": "#/components/responses/ToolValidationError"
          },
          "500": {
            "$ref": "#/components/responses/ToolExecutionError"
          }
        },
        "x-codeSamples": [
          {
            "lang": "Shell",
            "label": "curl",
            "source": "curl -X POST '{{apiUrl}}api/v1/workspaces/{{workspaceId}}/data-sources' \\\n  -H 'Content-Type: application/json' \\\n  -H 'Cookie: _sqlbook_session=<session-cookie>' \\\n  --data '{\"name\":\"Ecomm Warehouse\",\"host\":\"db.example.com\",\"port\":5432,\"database_name\":\"sales\",\"username\":\"sqlbook\",\"password\":\"secret\",\"ssl_mode\":\"prefer\",\"selected_tables\":[\"public.orders\",\"public.customers\"]}'"
          }
        ]
      }
    },
    "/api/v1/workspaces/{workspace_id}/data-sources/validate-connection": {
      "post": {
        "operationId": "dataSourceValidateConnection",
        "summary": "Validate PostgreSQL connection",
        "description": "Tests a PostgreSQL connection without creating the data source. The response includes the tables that are discoverable with the supplied credentials, which makes it suitable for both the create flow and a chat-assisted validation step.",
        "tags": ["Data Sources"],
        "parameters": [
          {
            "$ref": "#/components/parameters/workspaceId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DataSourceConnectionValidationRequest"
              },
              "examples": {
                "postgresValidate": {
                  "summary": "Validate a PostgreSQL connection",
                  "value": {
                    "host": "db.example.com",
                    "port": 5432,
                    "database_name": "sales",
                    "username": "sqlbook",
                    "password": "secret",
                    "ssl_mode": "prefer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/DataSourceConnectionValidated"
          },
          "401": {
            "$ref": "#/components/responses/ToolUnauthorized"
          },
          "403": {
            "$ref": "#/components/responses/ToolForbidden"
          },
          "422": {
            "$ref": "#/components/responses/ToolValidationError"
          },
          "500": {
            "$ref": "#/components/responses/ToolExecutionError"
          }
        },
        "x-codeSamples": [
          {
            "lang": "Shell",
            "label": "curl",
            "source": "curl -X POST '{{apiUrl}}api/v1/workspaces/{{workspaceId}}/data-sources/validate-connection' \\\n  -H 'Content-Type: application/json' \\\n  -H 'Cookie: _sqlbook_session=<session-cookie>' \\\n  --data '{\"host\":\"db.example.com\",\"port\":5432,\"database_name\":\"sales\",\"username\":\"sqlbook\",\"password\":\"secret\",\"ssl_mode\":\"prefer\"}'"
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "_sqlbook_session",
        "description": "Use the authenticated sqlbook session cookie."
      }
    },
    "parameters": {
      "workspaceId": {
        "name": "workspace_id",
        "in": "path",
        "required": true,
        "description": "The current workspace id.",
        "schema": {
          "type": "integer",
          "example": 7
        }
      },
      "memberId": {
        "name": "id",
        "in": "path",
        "required": true,
        "description": "The target workspace member id.",
        "schema": {
          "type": "integer",
          "example": 27
        }
      }
    },
    "responses": {
      "WorkspaceRenamed": {
        "description": "Workspace name updated",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/WorkspaceRenamedResponse"
            },
            "examples": {
              "success": {
                "value": {
                  "status": "executed",
                  "message": "Workspace name updated to Bumanarama.",
