<main>
  <h1><%= I18n.t('app.account_settings.title') %></h1>

  <div class="tabs">
    <%= render "shared/tabs/nav_item", tab: "general", name: I18n.t('app.account_settings.tabs.general'), icon_class: "ri-account-circle-line", default_selected: true %>
    <%= render "shared/tabs/nav_item", tab: "notifications", name: I18n.t('app.account_settings.tabs.notifications'), icon_class: "ri-notification-2-line" %>
    <%= render "shared/tabs/nav_item", tab: "delete_account", name: I18n.t('app.account_settings.tabs.delete_account'), icon_class: "ri-delete-bin-line" %>
  </div>

  <% if active_tab?(tab: "general", default_selected: true) %>
    <div class="container md" data-controller="form" data-form-require-change-value="true">
      <%= form_with url: app_account_settings_path, method: :patch, class: "account-settings-form", html: { "data-form-target": "form" } do |form| %>
        <p><%= I18n.t('app.account_settings.general.description') %></p>

        <%= form.label :first_name, I18n.t('app.account_settings.general.fields.first_name'), class: "label block" %>
        <%= form.text_field :first_name,
                            class: "input block fluid",
                            autocomplete: "given-name",
                            value: @account_user.first_name,
                            placeholder: I18n.t('app.account_settings.general.placeholders.first_name'),
                            required: true %>

        <%= form.label :last_name, I18n.t('app.account_settings.general.fields.last_name'), class: "label block" %>
        <%= form.text_field :last_name,
                            class: "input block fluid",
                            autocomplete: "family-name",
                            value: @account_user.last_name,
                            placeholder: I18n.t('app.account_settings.general.placeholders.last_name'),
                            required: true %>

        <%= form.label :email, I18n.t('app.account_settings.general.fields.email'), class: "label block" %>
        <%= form.email_field :email,
                             class: "input block fluid",
                             autocomplete: "email",
                             value: @account_user.email,
                             placeholder: I18n.t('app.account_settings.general.placeholders.email'),
                             required: true %>

        <%= form.label :preferred_locale, I18n.t('app.account_settings.general.fields.language'), class: "label block" %>
        <div class="select block fluid">
          <%= form.select :preferred_locale,
                          options_for_select([[I18n.t('locales.en'), 'en'], [I18n.t('locales.es'), 'es']], @account_user.preferred_locale || I18n.default_locale.to_s) %>
          <i class="ri-arrow-drop-down-line"></i>
        </div>

        <div class="submit">
          <%= form.submit I18n.t('app.account_settings.actions.save'), class: "link primary", "data-form-target": "submit", disabled: true %>
        </div>
      <% end %>
    </div>
  <% end %>

  <% if active_tab?(tab: "notifications") %>
    <div class="container md"></div>
  <% end %>

  <% if active_tab?(tab: "delete_account") %>
    <div class="container lg delete-account-tab" data-controller="account-delete">
      <p class="label"><%= I18n.t('app.account_settings.delete_account.title') %></p>
      <ul class="delete-account-guidance">
        <li><%= I18n.t('app.account_settings.delete_account.guidance.only_member') %></li>
        <li><%= I18n.t('app.account_settings.delete_account.guidance.owner_options') %></li>
        <li><%= I18n.t('app.account_settings.delete_account.guidance.confirmation_email') %></li>
        <li><%= I18n.t('app.account_settings.delete_account.guidance.irreversible') %></li>
      </ul>

      <button type="button" class="link primary delete-account-trigger show" data-account-delete-target="openButton" data-action="account-delete#show">
        <%= I18n.t('app.account_settings.actions.delete_account') %>
      </button>

      <div class="message account-delete-dialog" data-account-delete-target="dialog">
        <div class="body">
          <div class="account-delete-dialog-heading">
            <i class="ri-error-warning-line red-500" aria-hidden="true"></i>
            <p class="account-delete-dialog-title cream-250"><b><%= I18n.t('app.account_settings.delete_account.dialog.title') %></b></p>
          </div>
          <p class="account-delete-dialog-description"><%= I18n.t('app.account_settings.delete_account.dialog.description') %></p>

          <%= form_with url: app_account_settings_path, method: :delete, class: "account-delete-form", html: { "data-account-delete-target": "form" } do %>
            <% if @owned_workspace_rows.any? %>
              <div data-controller="table">
                <table class="collapsible account-delete-workspaces-table">
                  <tr>
                    <th>
                      <span class="truncate-text" data-tooltip-text="<%= I18n.t('app.account_settings.delete_account.table.workspace_name') %>"><%= I18n.t('app.account_settings.delete_account.table.workspace_name') %></span>
                    </th>
                    <th>
                      <span class="truncate-text" data-tooltip-text="<%= I18n.t('app.account_settings.delete_account.table.current_owner') %>"><%= I18n.t('app.account_settings.delete_account.table.current_owner') %></span>
                    </th>
                    <th>
                      <span class="truncate-text" data-tooltip-text="<%= I18n.t('app.account_settings.delete_account.table.new_owner') %>"><%= I18n.t('app.account_settings.delete_account.table.new_owner') %></span>
                    </th>
                  </tr>
                  <% @owned_workspace_rows.each do |row| %>
                    <% workspace = row[:workspace] %>
                    <% eligible_members = row[:eligible_members] %>
                    <tr>
                      <td>
                        <span class="truncate-text" data-tooltip-text="<%= workspace.name %>"><%= workspace.name %></span>
                      </td>
                      <td>
                        <span class="truncate-text" data-tooltip-text="<%= "#{@account_user.full_name} #{I18n.t('app.account_settings.delete_account.table.you')}" %>"><%= @account_user.full_name %> <span class="gray-300"><%= I18n.t('app.account_settings.delete_account.table.you') %></span></span>
                      </td>
                      <td>
                        <% if eligible_members.empty? %>
                          <%= hidden_field_tag "workspace_actions[#{workspace.id}]", AccountDeletionService::DELETE_WORKSPACE_ACTION %>
                          <span class="truncate-text" data-tooltip-text="<%= I18n.t('app.account_settings.delete_account.table.no_team_members') %>"><%= I18n.t('app.account_settings.delete_account.table.no_team_members') %></span>
                        <% else %>
                          <div class="select account-delete-select">
                            <%= select_tag "workspace_actions[#{workspace.id}]",
                                           options_for_select(
                                             [[I18n.t('app.account_settings.delete_account.table.please_select'), ""]] +
                                             eligible_members.map { |member| [member.user.full_name, member.id] } +
                                             [[I18n.t('app.account_settings.delete_account.table.delete_workspace'), AccountDeletionService::DELETE_WORKSPACE_ACTION]]
                                           ),
                                           class: "account-delete-select-input",
                                           required: true,
                                           data: {
                                             account_delete_target: "actionSelect",
                                             action: "change->account-delete#updateConfirmState"
                                           } %>
                            <i class="ri-arrow-drop-down-line"></i>
                          </div>
                        <% end %>
                      </td>
                    </tr>
                  <% end %>
                </table>
              </div>
            <% else %>
              <p class="account-delete-empty-state"><%= I18n.t('app.account_settings.delete_account.empty_state') %></p>
            <% end %>

            <p class="account-delete-confirm-label cream-250"><b><%= I18n.t('app.account_settings.delete_account.confirm_label') %></b></p>

            <div class="actions">
              <%= submit_tag I18n.t('app.account_settings.actions.confirm_delete'), class: "link primary", disabled: true, "data-account-delete-target": "submit" %>
              <button type="button" class="link secondary" data-action="account-delete#hide"><%= I18n.t('app.account_settings.actions.cancel') %></button>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</main>
