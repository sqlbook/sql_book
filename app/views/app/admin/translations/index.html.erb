<main>
  <h1><%= I18n.t('admin.translations.title') %></h1>

  <div class="container translations-admin" data-controller="translations-admin">
    <% selected_status = params[:status].presence || 'all' %>
    <% target_locale = params[:target_locale].presence || 'es' %>
    <%= form_with url: app_admin_translations_path, method: :get, class: 'translations-filters' do %>
      <div class="translations-filters-grid">
        <div>
          <label class="label block" for="translations-query"><%= I18n.t('admin.translations.filters.search') %></label>
          <input id="translations-query" class="input block fluid" type="text" name="q" value="<%= params[:q] %>" />
        </div>

        <div>
          <label class="label block" for="translations-area-tag"><%= I18n.t('admin.translations.filters.area_tag') %></label>
          <div class="select block fluid">
            <select id="translations-area-tag" name="area_tag">
              <option value=""><%= I18n.t('admin.translations.filters.any') %></option>
              <% @area_tags.each do |tag| %>
                <option value="<%= tag %>" <%= 'selected' if params[:area_tag] == tag %>><%= tag %></option>
              <% end %>
            </select>
            <i class="ri-arrow-drop-down-line"></i>
          </div>
        </div>

        <div>
          <label class="label block" for="translations-type-tag"><%= I18n.t('admin.translations.filters.type_tag') %></label>
          <div class="select block fluid">
            <select id="translations-type-tag" name="type_tag">
              <option value=""><%= I18n.t('admin.translations.filters.any') %></option>
              <% @type_tags.each do |tag| %>
                <option value="<%= tag %>" <%= 'selected' if params[:type_tag] == tag %>><%= tag %></option>
              <% end %>
            </select>
            <i class="ri-arrow-drop-down-line"></i>
          </div>
        </div>

        <div>
          <label class="label block" for="translations-status"><%= I18n.t('admin.translations.filters.status') %></label>
          <div class="select block fluid">
            <select id="translations-status" name="status">
              <option value="all" <%= 'selected' if selected_status == 'all' %>><%= I18n.t('admin.translations.filters.status_options.all') %></option>
              <option value="fully_translated" <%= 'selected' if selected_status == 'fully_translated' %>><%= I18n.t('admin.translations.filters.status_options.fully_translated') %></option>
              <option value="missing_translations" <%= 'selected' if selected_status == 'missing_translations' %>><%= I18n.t('admin.translations.filters.status_options.missing_translations') %></option>
              <option value="duplicate_english" <%= 'selected' if selected_status == 'duplicate_english' %>><%= I18n.t('admin.translations.filters.status_options.duplicate_english') %></option>
            </select>
            <i class="ri-arrow-drop-down-line"></i>
          </div>
        </div>

        <div class="translations-filter-submit">
          <button type="submit" class="link secondary"><%= I18n.t('common.actions.apply_filters') %></button>
        </div>
      </div>
      <%= hidden_field_tag :target_locale, target_locale %>
      <% if params[:duplicate_value].present? %>
        <%= hidden_field_tag :duplicate_value, params[:duplicate_value] %>
      <% end %>
    <% end %>

    <%= form_with url: app_admin_translations_path, method: :patch, class: 'translations-form', html: { "data-translations-admin-target": "form" } do %>
      <% preserved_filter_params = params.permit(:q, :area_tag, :type_tag, :status, :target_locale, :duplicate_value).to_h %>
      <% preserved_filter_params.each do |key, value| %>
        <%= hidden_field_tag key, value %>
      <% end %>

      <div class="translations-form-actions">
        <button type="submit" class="link primary" disabled data-translations-admin-target="saveButton">
          <%= I18n.t('common.actions.save') %>
        </button>
        <button type="button" class="link secondary" disabled data-action="translations-admin#discard" data-translations-admin-target="discardButton">
          <%= I18n.t('admin.translations.actions.discard') %>
        </button>
      </div>

      <div class="translations-table-wrapper" data-controller="table">
        <table class="collapsible translations-table">
          <colgroup>
            <col class="translations-col-key" />
            <col class="translations-col-tags" />
            <col class="translations-col-tags" />
            <col class="translations-col-wide" />
            <col class="translations-col-wide" />
            <% @target_locales.each do %>
              <col class="translations-col-wide" />
            <% end %>
            <col class="translations-col-actions" />
          </colgroup>
          <tr>
            <th><%= I18n.t('admin.translations.table.key') %></th>
            <th><%= I18n.t('admin.translations.table.area_tags') %></th>
            <th><%= I18n.t('admin.translations.table.type_tags') %></th>
            <th><%= I18n.t('admin.translations.table.english') %></th>
            <th><%= I18n.t('admin.translations.table.used_in') %></th>
            <% @target_locales.each do |locale| %>
              <th><%= I18n.t("locales.#{locale}", default: locale.upcase) %></th>
            <% end %>
            <th class="actions"><%= I18n.t('admin.translations.table.actions') %></th>
          </tr>
          <% @translation_keys.each do |translation_key| %>
            <% english_value = translation_value_for(translation_key:, locale: 'en', suggestions: @translation_suggestions) %>
            <% duplicate_count = duplicate_english_count_for(value: english_value, duplicate_counts: @duplicate_english_counts) %>
            <tr>
              <td>
                <span class="truncate-text" data-tooltip-text="<%= translation_key.key %>"><%= translation_key.key %></span>
                <% if duplicate_count.present? %>
                  <div class="translations-duplicate-meta">
                    <span><%= I18n.t('admin.translations.table.duplicate_text_count', count: duplicate_count) %></span>
                    <%= link_to I18n.t('admin.translations.table.show_duplicates'),
                                app_admin_translations_path(
                                  preserved_filter_params.merge(
                                    status: 'duplicate_english',
                                    duplicate_value: english_value,
                                    q: nil
                                  )
                                ),
                                class: 'link secondary' %>
                  </div>
                <% end %>
                <%= hidden_field_tag "rows[#{translation_key.id}][id]", translation_key.id %>
              </td>
              <td>
                <input type="text"
                       class="input block fluid"
                       value="<%= translation_key.area_tags.join(', ') %>"
                       name="rows[<%= translation_key.id %>][area_tags]"
                       data-translations-admin-target="field" />
              </td>
              <td>
                <input type="text"
                       class="input block fluid"
                       value="<%= translation_key.type_tags.join(', ') %>"
                       name="rows[<%= translation_key.id %>][type_tags]"
                       data-translations-admin-target="field" />
              </td>
              <td>
                <textarea class="input block fluid translations-value"
                          name="rows[<%= translation_key.id %>][en]"
                          rows="3"
                          data-translations-admin-target="field"><%= english_value %></textarea>
              </td>
              <td>
                <% entries = used_in_entries(translation_key:) %>
                <div class="translations-used-in-list">
                  <% if entries.empty? %>
                    <span class="grey-500">-</span>
                  <% else %>
                    <% entries.each do |entry| %>
                      <% if used_in_path_linkable?(path: entry[:path]) %>
                        <%= link_to entry[:label], entry[:path], class: 'link secondary' %>
                      <% else %>
                        <span><%= entry[:label] %></span>
                      <% end %>
                    <% end %>
                  <% end %>
                </div>
              </td>
              <% @target_locales.each do |locale| %>
                <% value = translation_value_for(translation_key:, locale:, suggestions: @translation_suggestions) %>
                <td>
                  <textarea class="input block fluid translations-value"
                            name="rows[<%= translation_key.id %>][<%= locale %>]"
                            rows="3"
                            data-translations-admin-target="field"><%= value %></textarea>
                </td>
              <% end %>
              <td class="actions">
                <div class="translations-row-actions">
                  <%= link_to I18n.t('admin.translations.actions.translate_missing'),
                              translate_missing_app_admin_translation_path(translation_key, preserved_filter_params.merge(target_locale: target_locale)),
                              class: 'link secondary',
                              data: { turbo_method: :post } %>
                  <%= link_to I18n.t('admin.translations.actions.history'),
                              history_app_admin_translation_path(translation_key),
                              class: 'link secondary',
                              target: '_blank',
                              rel: 'noreferrer' %>
                </div>
              </td>
            </tr>
          <% end %>
        </table>
      </div>
    <% end %>
  </div>
</main>
