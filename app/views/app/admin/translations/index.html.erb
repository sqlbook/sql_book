<main>
  <div class="container translations-admin" data-controller="translations-admin">
    <div class="translations-header-row">
      <h1>Translations Manager</h1>
      <div class="translations-form-actions">
        <button type="submit" form="translations-form" class="link primary" disabled data-translations-admin-target="saveButton">
          [Save]
        </button>
        <button type="button" class="link secondary" disabled data-action="translations-admin#discard" data-translations-admin-target="discardButton">
          Discard changes
        </button>
      </div>
    </div>

    <% selected_status = params[:status].presence || 'all' %>
    <% target_locale = params[:target_locale].presence || 'es' %>
    <%= form_with url: app_admin_translations_path, method: :get, class: 'translations-filters', html: { "data-translations-admin-target": "filterForm" } do %>
      <div class="translations-filters-grid">
        <div>
          <label class="label block" for="translations-query">Search</label>
          <input id="translations-query" class="input block fluid" type="text" name="q" value="<%= params[:q] %>" data-translations-admin-target="filterField" />
        </div>

        <div>
          <label class="label block" for="translations-type-tag">Type</label>
          <div class="select block fluid">
            <select id="translations-type-tag" name="type_tag" data-translations-admin-target="filterField">
              <option value="">Any</option>
              <% @type_tags.each do |tag| %>
                <option value="<%= tag %>" <%= 'selected' if params[:type_tag] == tag %>><%= tag %></option>
              <% end %>
            </select>
            <i class="ri-arrow-drop-down-line"></i>
          </div>
        </div>

        <div>
          <label class="label block" for="translations-status">Status</label>
          <div class="select block fluid">
            <select id="translations-status" name="status" data-translations-admin-target="filterField">
              <option value="all" <%= 'selected' if selected_status == 'all' %>>All</option>
              <option value="fully_translated" <%= 'selected' if selected_status == 'fully_translated' %>>Fully translated</option>
              <option value="missing_translations" <%= 'selected' if selected_status == 'missing_translations' %>>Missing translations</option>
            </select>
            <i class="ri-arrow-drop-down-line"></i>
          </div>
        </div>
      </div>
      <%= hidden_field_tag :target_locale, target_locale %>
    <% end %>

    <%= form_with url: app_admin_translations_path, method: :patch, class: 'translations-form', id: 'translations-form', html: { "data-translations-admin-target": "form" } do %>
      <% preserved_filter_params = params.permit(:q, :type_tag, :status, :target_locale).to_h %>
      <% preserved_filter_params.each do |key, value| %>
        <%= hidden_field_tag key, value %>
      <% end %>

      <div class="translations-table-wrapper" data-controller="table">
        <table class="collapsible translations-table">
          <colgroup>
            <col class="translations-col-key" />
            <col class="translations-col-tags" />
            <col class="translations-col-wide" />
            <col class="translations-col-wide" />
            <% @target_locales.each do %>
              <col class="translations-col-wide" />
            <% end %>
            <col class="translations-col-actions" />
          </colgroup>
          <tr>
            <th>Key</th>
            <th>Type</th>
            <th>Used in</th>
            <th>English</th>
            <% @target_locales.each do |locale| %>
              <th><%= locale.upcase %></th>
            <% end %>
            <th class="actions">Actions</th>
          </tr>
          <% @translation_keys.each do |translation_key| %>
            <% english_value = translation_value_for(translation_key:, locale: 'en', suggestions: @translation_suggestions) %>
            <tr>
              <td>
                <span class="truncate-text" data-tooltip-text="<%= translation_key.key %>"><%= translation_key.key %></span>
                <%= hidden_field_tag "rows[#{translation_key.id}][id]", translation_key.id %>
              </td>
              <td>
                <% type_tags_text = translation_key.type_tags.join(', ') %>
                <span class="truncate-text" data-tooltip-text="<%= type_tags_text %>"><%= type_tags_text %></span>
              </td>
              <td>
                <% entries = used_in_entries(translation_key:) %>
                <div class="translations-used-in-list">
                  <% if entries.empty? %>
                    <span class="grey-500">-</span>
                  <% else %>
                    <% entries.each_with_index do |entry, index| %>
                      <% resolved_path = resolve_used_in_path(path: entry[:path]) %>
                      <% if used_in_path_linkable?(path: resolved_path) %>
                        <%= link_to entry[:label], resolved_path, class: 'link secondary' %>
                      <% else %>
                        <span><%= entry[:label] %></span>
                      <% end %>
                      <% if index < entries.length - 1 %>
                        <span class="translations-used-in-separator">, </span>
                      <% end %>
                    <% end %>
                  <% end %>
                </div>
              </td>
              <td>
                <textarea class="input block fluid translations-value"
                          name="rows[<%= translation_key.id %>][en]"
                          rows="3"
                          readonly
                          tabindex="-1"><%= english_value %></textarea>
              </td>
              <% @target_locales.each do |locale| %>
                <% value = translation_value_for(translation_key:, locale:, suggestions: @translation_suggestions) %>
                <td>
                  <textarea class="input block fluid translations-value"
                            name="rows[<%= translation_key.id %>][<%= locale %>]"
                            rows="3"
                            data-initial-value="<%= persisted_translation_value_for(translation_key:, locale:) %>"
                            data-translations-admin-target="field"><%= value %></textarea>
                </td>
              <% end %>
              <td class="actions">
                <div class="translations-row-actions">
                  <%= link_to "Translate missing",
                              translate_missing_app_admin_translation_path(translation_key, preserved_filter_params.merge(target_locale: target_locale)),
                              class: 'link secondary',
                              data: { turbo_method: :post } %>
                  <%= link_to "View history",
                              history_app_admin_translation_path(translation_key),
                              class: 'link secondary',
                              target: '_blank',
                              rel: 'noreferrer' %>
                </div>
              </td>
            </tr>
          <% end %>
        </table>
      </div>
    <% end %>
  </div>
</main>
