<main class="workspace-chat-page <%= @chat_threads.any? ? 'chat-sidebar-open' : 'chat-sidebar-closed' %>"
      data-controller="workspace-chat"
      data-workspace-chat-workspace-id-value="<%= @workspace.id %>"
      data-workspace-chat-thread-id-value="<%= @chat_thread&.id || 0 %>"
      data-workspace-chat-sidebar-default-open-value="<%= @chat_threads.any? %>"
      data-workspace-chat-new-chat-path-value="<%= app_workspace_path(@workspace, new_chat: 1) %>"
      data-workspace-chat-mobile-breakpoint-value="760"
      data-workspace-chat-i18n-value="<%= json_escape({
        maxImagesError: I18n.t('app.workspaces.chat.errors.max_images', count: ChatMessage::MAX_IMAGE_COUNT),
        unsupportedImagesError: I18n.t('app.workspaces.chat.errors.unsupported_images'),
        imageTooLargeError: I18n.t('app.workspaces.chat.errors.image_too_large'),
        messageRequiredError: I18n.t('app.workspaces.chat.errors.message_or_image_required'),
        genericError: I18n.t('app.workspaces.chat.errors.request_failed'),
        confirmActionError: I18n.t('app.workspaces.chat.errors.confirm_failed'),
        cancelActionError: I18n.t('app.workspaces.chat.errors.cancel_failed'),
        requestFailedError: I18n.t('app.workspaces.chat.errors.request_failed'),
        threadTitleRequiredError: I18n.t('app.workspaces.chat.errors.thread_title_required'),
        deleteThreadFailedError: I18n.t('app.workspaces.chat.errors.delete_thread_failed'),
        renameThreadFailedError: I18n.t('app.workspaces.chat.errors.rename_thread_failed'),
        thinkingStatus: I18n.t('app.workspaces.chat.statuses.thinking'),
        removeAttachmentAria: I18n.t('app.workspaces.chat.composer.remove_image_aria_label', filename: '%{filename}'),
        deleteThreadConfirmation: I18n.t('app.workspaces.chat.sidebar.delete_confirmation'),
        sidebarOpenAria: I18n.t('app.workspaces.chat.sidebar.actions.open_aria'),
        sidebarCloseAria: I18n.t('app.workspaces.chat.sidebar.actions.close_aria')
      }.to_json) %>">
  <aside class="chat-history-sidebar" data-workspace-chat-target="sidebar">
    <header class="chat-history-sidebar-header">
      <h2><%= I18n.t('app.workspaces.chat.sidebar.heading') %></h2>

      <div class="chat-history-sidebar-header-actions">
        <button type="button"
                class="chat-sidebar-icon-button"
                data-action="workspace-chat#startNewChat"
                aria-label="<%= I18n.t('app.workspaces.chat.sidebar.actions.new_chat_aria') %>">
          <i class="ri-add-circle-line"></i>
        </button>

        <button type="button"
                class="chat-sidebar-icon-button"
                data-action="workspace-chat#toggleSidebar"
                data-workspace-chat-target="sidebarCloseButton"
                aria-label="<%= I18n.t('app.workspaces.chat.sidebar.actions.close_aria') %>">
          <i class="ri-sidebar-fold-line"></i>
        </button>
      </div>
    </header>

    <div class="chat-history-sidebar-search">
      <input type="search"
             class="input block fluid chat-history-search-input"
             placeholder="<%= I18n.t('app.workspaces.chat.sidebar.search_placeholder') %>"
             data-workspace-chat-target="threadSearchInput"
             data-action="input->workspace-chat#searchThreads" />
      <button type="button"
              class="chat-history-search-clear"
              data-workspace-chat-target="threadSearchClear"
              data-action="workspace-chat#clearThreadSearch"
              aria-label="<%= I18n.t('app.workspaces.chat.sidebar.actions.clear_search_aria') %>">
        <i class="ri-close-line"></i>
      </button>
    </div>

    <div class="chat-history-sidebar-list" data-workspace-chat-target="threadList">
      <% @chat_threads.each do |thread| %>
        <% thread_title = thread.title.presence || I18n.t('app.workspaces.chat.threads.untitled') %>
        <% thread_active = @chat_thread&.id == thread.id %>
        <div class="chat-history-thread-row <%= 'is-active' if thread_active %>"
             data-workspace-chat-target="threadRow"
             data-thread-id="<%= thread.id %>"
             data-thread-title="<%= thread_title.downcase %>"
             data-thread-path="<%= app_workspace_path(@workspace, thread_id: thread.id) %>">
          <button type="button"
                  class="chat-history-thread-open"
                  data-action="workspace-chat#openThread">
            <span class="chat-history-thread-title"><%= thread_title %></span>
            <input type="text"
                   class="chat-history-thread-title-input"
                   value="<%= thread_title %>"
                   data-action="keydown->workspace-chat#renameKeydown blur->workspace-chat#renameBlur" />
          </button>

          <div class="chat-history-thread-actions">
            <button type="button"
                    class="chat-history-thread-menu-toggle"
                    data-action="workspace-chat#toggleThreadMenu"
                    aria-label="<%= I18n.t('app.workspaces.chat.sidebar.actions.thread_menu_aria') %>">
              <i class="ri-more-2-fill"></i>
            </button>

            <div class="chat-history-thread-menu">
              <button type="button"
                      class="link secondary chat-history-thread-menu-item"
                      data-action="workspace-chat#beginRenameThread">
                <%= I18n.t('common.actions.rename') %>
              </button>
              <button type="button"
                      class="link secondary chat-history-thread-menu-item"
                      data-action="workspace-chat#deleteThread">
                <%= I18n.t('common.actions.delete') %>
              </button>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <p class="chat-history-sidebar-empty <%= 'visible' if @chat_threads.empty? %>"
       data-workspace-chat-target="threadListEmpty">
      <%= I18n.t('app.workspaces.chat.sidebar.empty') %>
    </p>
  </aside>

  <section class="chat-pane">
    <button type="button"
            class="chat-sidebar-icon-button chat-pane-sidebar-open"
            data-workspace-chat-target="sidebarOpenButton"
            data-action="workspace-chat#toggleSidebar"
            aria-label="<%= I18n.t('app.workspaces.chat.sidebar.actions.open_aria') %>">
      <i class="ri-sidebar-unfold-line"></i>
    </button>

    <% if @chat_messages.empty? %>
      <section class="chat-empty-state">
        <%= image_tag "waving-quokka.svg", alt: "", class: "chat-empty-state-image", width: 72, height: 72 %>

        <h1><%= I18n.t('app.workspaces.chat.title') %></h1>

        <div class="chat-suggestion-chips">
          <% @chat_suggestions.each do |suggestion| %>
            <button type="button"
                    class="chat-suggestion-chip"
                    data-action="workspace-chat#useSuggestion"
                    data-suggestion="<%= suggestion %>">
              <%= suggestion %>
            </button>
          <% end %>
        </div>

        <%= form_with url: app_workspace_chat_messages_path(@workspace),
                      method: :post,
                      class: "chat-composer chat-composer-empty",
                      html: { "data-workspace-chat-target": "form", "data-action": "submit->workspace-chat#submit" } do |form| %>
          <% if @chat_thread.present? %>
            <%= hidden_field_tag :thread_id, @chat_thread.id, "data-workspace-chat-target": "threadInput" %>
          <% end %>

          <div class="chat-composer-input-row">
            <%= form.text_field :content,
                                class: "input block fluid chat-composer-input",
                                placeholder: I18n.t('app.workspaces.chat.composer.placeholder_empty'),
                                autocomplete: "off",
                                "data-workspace-chat-target": "textInput" %>

            <label class="chat-attachment-button" aria-label="<%= I18n.t('app.workspaces.chat.composer.attach_images_aria_label') %>">
              <i class="ri-attachment-2"></i>
              <%= file_field_tag :images,
                                 multiple: true,
                                 accept: "image/png,image/jpeg,image/webp,image/gif",
                                 class: "chat-attachment-input",
                                 "data-workspace-chat-target": "fileInput",
                                 "data-action": "change->workspace-chat#onFileChange" %>
            </label>
          </div>

          <div class="chat-attachment-tray" data-workspace-chat-target="attachmentTray"></div>
          <p class="chat-attachment-error" data-workspace-chat-target="attachmentError"></p>

          <p class="chat-composer-hint"><%= I18n.t('app.workspaces.chat.composer.submit_hint') %></p>
          <%= form.submit I18n.t('common.actions.send'), class: "chat-composer-submit" %>
        <% end %>
      </section>
    <% else %>
      <section class="chat-message-stream" data-workspace-chat-target="messages">
        <% @chat_messages.each do |message| %>
          <%= render "app/workspaces/chat/message",
                     message:,
                     action_requests_by_id: @chat_action_requests_by_id %>
        <% end %>
      </section>

      <%= form_with url: app_workspace_chat_messages_path(@workspace),
                    method: :post,
                    class: "chat-composer chat-composer-sticky",
                    html: { "data-workspace-chat-target": "form", "data-action": "submit->workspace-chat#submit" } do |form| %>
        <% if @chat_thread.present? %>
          <%= hidden_field_tag :thread_id, @chat_thread.id, "data-workspace-chat-target": "threadInput" %>
        <% end %>

        <div class="chat-composer-input-row">
          <%= form.text_field :content,
                              class: "input block fluid chat-composer-input",
                              placeholder: I18n.t('app.workspaces.chat.composer.placeholder_active'),
                              autocomplete: "off",
                              "data-workspace-chat-target": "textInput" %>

          <label class="chat-attachment-button" aria-label="<%= I18n.t('app.workspaces.chat.composer.attach_images_aria_label') %>">
            <i class="ri-attachment-2"></i>
            <%= file_field_tag :images,
                               multiple: true,
                               accept: "image/png,image/jpeg,image/webp,image/gif",
                               class: "chat-attachment-input",
                               "data-workspace-chat-target": "fileInput",
                               "data-action": "change->workspace-chat#onFileChange" %>
          </label>
        </div>

        <div class="chat-attachment-tray" data-workspace-chat-target="attachmentTray"></div>
        <p class="chat-attachment-error" data-workspace-chat-target="attachmentError"></p>
        <%= form.submit I18n.t('common.actions.send'), class: "chat-composer-submit" %>
      <% end %>
    <% end %>
  </section>
</main>
