<aside class="data-source-panel">
  <div class="data-source-panel__header">
    <h3><%= data_source.display_name %></h3>
    <%= link_to "[#{I18n.t('common.actions.close')}]", add_params(data_source_id: nil, tab: nil, confirm_delete: nil), class: "link secondary" %>
  </div>

  <div class="tabs">
    <% if data_source.capture_source? %>
      <%= render "shared/tabs/nav_item", tab: "source_url", name: I18n.t('app.workspaces.data_sources.management.fields.tracking_url'), icon_class: "ri-global-line", default_selected: true %>
      <%= render "shared/tabs/nav_item", tab: "tracking_code", name: I18n.t('app.workspaces.data_sources.management.tracking_code_title'), icon_class: "ri-fire-line" %>
    <% else %>
      <%= render "shared/tabs/nav_item", tab: "settings", name: I18n.t('common.actions.settings'), icon_class: "ri-settings-3-line", default_selected: true %>
    <% end %>
    <%= render "shared/tabs/nav_item", tab: "source_deletion", name: I18n.t('app.workspaces.data_sources.management.deletion_title'), icon_class: "ri-delete-bin-line" %>
  </div>

  <% if data_source.capture_source? && active_tab?(tab: "source_url", default_selected: true) %>
    <div data-controller="form">
      <%= form_with url: app_workspace_data_source_path(workspace, data_source), method: :put, class: "update-data-source-form", html: { "data-form-target": "form" } do |form| %>
        <%= form.label :url, I18n.t('app.workspaces.data_sources.management.fields.tracking_url'), class: "label block" %>
        <%= form.text_field :url, type: "url", placeholder: "https://", class: "input block fluid", required: true, pattern: "https://.*", value: data_source.url %>

        <%= render "shared/flash" %>

        <%= form.submit I18n.t('common.actions.save_changes'), class: "link primary", "data-form-target": "submit" %>
      <% end %>
    </div>
  <% end %>

  <% if data_source.capture_source? && active_tab?(tab: "tracking_code") %>
    <%= render "shared/tracking_code", data_source: data_source %>
  <% end %>

  <% if data_source.external_database? && active_tab?(tab: "settings", default_selected: true) %>
    <% form_state = @selected_data_source_form_state || {} %>
    <% form_errors = @selected_data_source_errors || {} %>
    <% available_tables = @selected_data_source_available_tables || [] %>
    <div class="data-source-management">
      <%= form_with url: app_workspace_data_source_path(workspace, data_source), method: :put, class: "data-source-management__form" do %>
        <% if @selected_data_source_connection_error.present? %>
          <div class="message data-source-management__error-dialogue">
            <i class="ri-error-warning-line ri-lg red-500"></i>
            <div class="body">
              <p><%= @selected_data_source_connection_error %></p>
            </div>
          </div>
        <% end %>

        <div class="data-source-management__fields">
          <div class="field">
            <%= label_tag :display_name, I18n.t('app.workspaces.data_sources.new.fields.name'), class: "label block" %>
            <%= text_field_tag :display_name, data_source.display_name, class: "input block fluid", disabled: true %>
          </div>

          <div class="field">
            <%= label_tag :source_type, I18n.t('app.workspaces.data_sources.management.fields.type'), class: "label block" %>
            <%= text_field_tag :source_type, data_source_index_type_label(data_source), class: "input block fluid", disabled: true %>
          </div>
        </div>

        <div class="data-source-management__section">
          <h3><%= I18n.t('app.workspaces.data_sources.management.connection_title') %></h3>

          <div class="data-source-management__connection-box">
            <div class="data-source-management__grid">
              <div class="field">
                <%= label_tag :host, I18n.t('app.workspaces.data_sources.management.fields.host'), class: "label block" %>
                <%= text_field_tag :host,
                                   form_state['host'],
                                   class: class_names("input block fluid", invalid: form_errors['host'].present?),
                                   required: true %>
                <% if form_errors['host'].present? %>
                  <p class="field-error"><%= form_errors['host'].first %></p>
                <% end %>
              </div>

              <div class="field field--narrow">
                <%= label_tag :port, I18n.t('app.workspaces.data_sources.management.fields.port'), class: "label block" %>
                <%= text_field_tag :port,
                                   form_state['port'],
                                   class: class_names("input block fluid", invalid: form_errors['port'].present?),
                                   required: true %>
                <% if form_errors['port'].present? %>
                  <p class="field-error"><%= form_errors['port'].first %></p>
                <% end %>
              </div>

              <div class="field field--full">
                <%= label_tag :database_name, I18n.t('app.workspaces.data_sources.management.fields.server_database_name'), class: "label block" %>
                <%= text_field_tag :database_name,
                                   form_state['database_name'],
                                   class: class_names("input block fluid", invalid: form_errors['database_name'].present?),
                                   required: true %>
                <% if form_errors['database_name'].present? %>
                  <p class="field-error"><%= form_errors['database_name'].first %></p>
                <% end %>
              </div>

              <div class="field field--full">
                <%= label_tag :username, I18n.t('app.workspaces.data_sources.management.fields.username'), class: "label block" %>
                <%= text_field_tag :username,
                                   form_state['username'],
                                   class: class_names("input block fluid", invalid: form_errors['username'].present?),
                                   required: true %>
                <% if form_errors['username'].present? %>
                  <p class="field-error"><%= form_errors['username'].first %></p>
                <% end %>
              </div>

              <div class="field field--full">
                <%= label_tag :password, I18n.t('app.workspaces.data_sources.new.fields.password'), class: "label block" %>
                <%= password_field_tag :password,
                                       nil,
                                       class: class_names("input block fluid", invalid: form_errors['connection_password'].present?),
                                       placeholder: I18n.t('app.workspaces.data_sources.management.fields.password_placeholder') %>
                <% if form_errors['connection_password'].present? %>
                  <p class="field-error"><%= form_errors['connection_password'].first %></p>
                <% end %>
              </div>

              <div class="field field--full">
                <label class="checkbox">
                  <%= hidden_field_tag :extract_category_values, '0' %>
                  <%= check_box_tag :extract_category_values, '1', ActiveModel::Type::Boolean.new.cast(form_state['extract_category_values']) %>
                  <div class="check">
                    <i class="ri-check-line"></i>
                  </div>
                  <span class="checkbox-text"><%= I18n.t('app.workspaces.data_sources.new.fields.extract_category_values') %></span>
                </label>
              </div>
            </div>
          </div>
        </div>

        <div class="data-source-management__section">
          <h3><%= I18n.t('app.workspaces.data_sources.management.selected_tables_title') %></h3>
          <p class="data-source-management__hint">
            <%= I18n.t('app.workspaces.data_sources.management.selected_tables_hint') %>
          </p>
          <% if form_errors['selected_tables'].present? %>
            <p class="field-error"><%= form_errors['selected_tables'].first %></p>
          <% end %>

          <div class="data-source-management__table-box">
            <div class="data-source-management__table-list">
              <% groups = wizard_available_table_groups(available_tables) %>
              <% selected_tables = Array(form_state['selected_tables']).map(&:to_s) %>
              <% if groups.any? %>
                <% groups.each do |group| %>
                  <details class="data-source-management__schema-group" open>
                    <summary class="data-source-management__schema-summary">
                      <span class="data-source-management__schema-name"><%= group[:schema] %></span>
                      <span class="data-source-management__schema-count"><%= group[:tables].size %></span>
                    </summary>

                    <div class="data-source-management__schema-tables">
                      <% group[:tables].each do |table| %>
                        <label class="checkbox data-source-management__table-row">
                          <%= check_box_tag 'selected_tables[]', table[:qualified_name], selected_tables.include?(table[:qualified_name]) %>
                          <div class="check">
                            <i class="ri-check-line"></i>
                          </div>
                          <span class="checkbox-text data-source-management__table-name"><%= table[:name] %></span>
                        </label>
                      <% end %>
                    </div>
                  </details>
                <% end %>
              <% else %>
                <div class="data-source-management__empty-tables">
                  <p><%= I18n.t('app.workspaces.data_sources.new.steps.tables.empty') %></p>
                </div>
              <% end %>
            </div>
          </div>
        </div>

        <%= submit_tag I18n.t('common.actions.save_changes'), class: "link primary" %>
      <% end %>
    </div>
  <% end %>

  <% if active_tab?(tab: "source_deletion") %>
    <p class="cream-250"><b><%= I18n.t('app.workspaces.data_sources.management.deletion_intro') %></b></p>
    <ul class="gray-250">
      <li><%= I18n.t('app.workspaces.data_sources.management.deletion_points.one') %></li>
      <li><%= I18n.t('app.workspaces.data_sources.management.deletion_points.two') %></li>
      <li>
        <%= data_source.capture_source? ?
              I18n.t('app.workspaces.data_sources.management.deletion_points.three_capture', name: data_source.display_name) :
              I18n.t('app.workspaces.data_sources.management.deletion_points.three_external') %>
      </li>
    </ul>

    <% if params[:confirm_delete] %>
      <div class="message">
        <i class="ri-error-warning-line ri-lg red-500"></i>
        <div class="body">
          <p class="title cream-250"><b><%= I18n.t('app.workspaces.data_sources.management.deletion_confirm_title') %></b></p>
          <p><%= I18n.t('app.workspaces.data_sources.management.deletion_confirm_body') %></p>
          <div class="actions">
            <%= link_to I18n.t('app.workspaces.data_sources.management.actions.delete'), app_workspace_data_source_path(workspace, data_source), class: "link primary", data: { turbo_method: :delete }, "aria-label": I18n.t('app.workspaces.data_sources.management.aria.confirm_delete') %>
            <%= link_to I18n.t('common.actions.cancel'), add_params(confirm_delete: nil), class: "link secondary", "aria-label": I18n.t('app.workspaces.data_sources.management.aria.cancel_delete') %>
          </div>
        </div>
      </div>
    <% else %>
      <%= link_to I18n.t('app.workspaces.data_sources.management.actions.delete'), add_params(confirm_delete: 1), class: "link primary", "aria-label": I18n.t('app.workspaces.data_sources.management.aria.delete') %>
    <% end %>
  <% end %>
</aside>
