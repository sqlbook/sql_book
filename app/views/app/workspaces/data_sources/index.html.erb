<main class="data-sources-page">
  <div class="page-header data-sources-page__header">
    <div class="data-sources-page__title-block">
      <p class="eyebrow gray-300"><%= t('app.workspaces.data_sources.index.eyebrow') %></p>
      <h1><%= t('app.workspaces.data_sources.index.title') %></h1>
    </div>

    <%= link_to new_app_workspace_data_source_path(@workspace),
                class: "link secondary create-data-source",
                "data-shortcut": "N",
                "aria-label": t('app.workspaces.data_sources.index.create_aria_label') do %>
      <i class="ri-add-line red-500"></i>
      <span><%= I18n.t('common.actions.create_new') %></span>
    <% end %>
  </div>

  <div class="data-sources-groups">
    <%= render partial: "index_group", collection: data_sources_index_sections(@data_sources), as: :section, locals: { workspace: @workspace, stats: @data_sources_stats } %>
  </div>
</main>
