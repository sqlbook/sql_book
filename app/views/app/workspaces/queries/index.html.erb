<main>
  <% can_write_queries = can_write_queries?(workspace: @workspace) %>
  <% can_create_queries = can_write_queries && @data_sources.any? %>

  <% if @queries.empty? %>
    <h1><%= I18n.t('app.workspaces.queries.index.title') %></h1>
    <p><%= I18n.t('app.workspaces.queries.index.empty') %></p>
    <% if can_create_queries %>
      <%= link_to I18n.t('app.workspaces.queries.index.create_new'), app_workspace_data_source_queries_path(@workspace, @data_sources.first), class: "link primary", "data-shortcut": "N", "aria-label": I18n.t('app.workspaces.queries.index.create_aria_label') %>
    <% end %>
  <% else %>
    <div class="page-header">
      <div class="title">
        <h1><%= I18n.t('app.workspaces.queries.index.title') %></h1>
        <% if can_create_queries %>
          <%= link_to app_workspace_data_source_queries_path(@workspace, @data_sources.first), class: "link secondary create-query", "data-shortcut": "N", "aria-label": I18n.t('app.workspaces.queries.index.create_aria_label') do %>
            <i class="ri-add-line red-500"></i>
            <span><%= I18n.t('common.actions.create_new') %></span>
          <% end %>
        <% end %>
      </div>
      <div class="controls" data-controller="search">
        <%= form_with url: app_workspace_queries_path(@workspace), method: :get, html: { "data-search-target": "form" } do |form| %>
          <%= form.text_field :search, type: "search", placeholder: I18n.t('app.workspaces.queries.index.search_placeholder'), value: params[:search], class: "input block search", "data-action": "search#change" %>
        <% end %>
      </div>
    </div>

    <div class="queries-table" data-controller="table">
      <table class="collapsible">
        <tr>
          <th><%= I18n.t('app.workspaces.queries.index.columns.name') %></th>
          <th><%= I18n.t('app.workspaces.queries.index.columns.data_source') %></th>
          <th><%= I18n.t('app.workspaces.queries.index.columns.original_author') %></th>
          <th><%= I18n.t('app.workspaces.queries.index.columns.date_created') %></th>
          <th><%= I18n.t('app.workspaces.queries.index.columns.last_updated') %></th>
          <th><%= I18n.t('app.workspaces.queries.index.columns.last_updated_by') %></th>
          <th><%= I18n.t('app.workspaces.queries.index.columns.last_run') %></th>
          <th class="options"></th>
        </tr>
        <% @queries.each do |query| %>
          <tr>
            <td>
              <%= link_to app_workspace_data_source_query_path(@workspace, query.data_source, query), class: "link name cream-250", "aria-label": "View the #{query.name} query" do %>
                <%= query.name %>
              <% end %>
            </td>
            <td><%= query.data_source.display_name %></td>
            <td><%= query.author.full_name %></td>
            <td><%= query.created_at.strftime('%a, %e %b %Y') %></td>
            <td><%= query.updated_at.strftime('%a, %e %b %Y') %></td>
            <td><%= query.last_updated_by&.full_name || '-' %></td>
            <td><%= query.last_run_at&.strftime('%a, %e %b %Y') || '-' %></td>
            <td class="options" >
              <button class="toggle-options" data-action="table#toggleOptions">
                <i class="ri-more-2-fill ri-xl gray-250"></i>
              </button>
              <div class="dropdown-options context">
                <%= link_to I18n.t('common.actions.open'), app_workspace_data_source_query_path(@workspace, query.data_source, query), class: "link", "aria-label": "View the #{query.name} query" %>
                <% if can_destroy_query?(workspace: @workspace, query:) %>
                  <%= link_to I18n.t('common.actions.delete'), app_workspace_data_source_query_path(@workspace, query.data_source, query), class: "link", data: { turbo_method: :delete }, "aria-label": "Delete the #{query.name} query" %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </table>
    </div>
  <% end %>
</main>
