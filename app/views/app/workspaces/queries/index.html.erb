<main>
  <% can_write_queries = can_write_queries?(workspace: @workspace) %>
  <% can_create_queries = can_write_queries && @data_sources.any? %>
  <% grouped_view = @view_mode == 'groups' %>

  <% if @queries.empty? && !grouped_view %>
    <h1><%= I18n.t('app.workspaces.queries.index.title') %></h1>
    <p><%= I18n.t('app.workspaces.queries.index.empty') %></p>
    <% if can_create_queries %>
      <%= link_to I18n.t('app.workspaces.queries.index.create_new'), app_workspace_data_source_queries_path(@workspace, @data_sources.first), class: "link primary", "data-shortcut": "N", "aria-label": I18n.t('app.workspaces.queries.index.create_aria_label') %>
    <% end %>
  <% else %>
    <div class="query-library-page"
         data-controller="query-library-columns query-library-groups"
         data-query-library-columns-update-url-value="<%= app_workspace_query_library_visible_columns_path(@workspace) %>"
         data-query-library-columns-csrf-token-value="<%= form_authenticity_token %>">
      <div class="page-header">
        <div class="title">
          <h1><%= I18n.t('app.workspaces.queries.index.title') %></h1>
          <% if can_create_queries %>
            <%= link_to app_workspace_data_source_queries_path(@workspace, @data_sources.first), class: "link secondary create-query", "data-shortcut": "N", "aria-label": I18n.t('app.workspaces.queries.index.create_aria_label') do %>
              <i class="ri-add-line red-500"></i>
              <span><%= I18n.t('common.actions.create_new') %></span>
            <% end %>
          <% end %>
        </div>
        <div class="controls" data-controller="search">
          <%= form_with url: app_workspace_queries_path(@workspace), method: :get, html: { "data-search-target": "form", class: "query-library-controls-form" } do |form| %>
            <div class="search-input-group">
              <%= form.text_field :search,
                                  type: "search",
                                  placeholder: I18n.t('app.workspaces.queries.index.search_placeholder'),
                                  value: params[:search],
                                  class: "input block search",
                                  "data-search-target": "input",
                                  "data-action": "input->search#queueSearch focus->search#rememberFocus blur->search#rememberBlur" %>
              <button type="button"
                      class="search-input-clear"
                      data-search-target="clear"
                      data-action="search#clear"
                      aria-label="<%= I18n.t('common.actions.clear_search') %>"
                      <%= 'hidden' if params[:search].blank? %>>
                <i class="ri-close-line" aria-hidden="true"></i>
              </button>
            </div>

            <div class="query-library-view-control">
              <label for="query-library-view" class="query-library-view-control__label"><%= I18n.t('app.workspaces.queries.index.view_label') %></label>
              <div class="select query-library-view-control__select">
                <%= form.select :view,
                                options_for_select(
                                  [
                                    [I18n.t('app.workspaces.queries.index.views.all'), 'all'],
                                    [I18n.t('app.workspaces.queries.index.views.groups'), 'groups']
                                  ],
                                  @view_mode
                                ),
                                {},
                                id: 'query-library-view',
                                "data-action": "change->search#submitWithoutFocusRestore" %>
                <i class="ri-arrow-drop-down-line"></i>
              </div>
            </div>
          <% end %>

          <menu data-controller="menu" class="query-library-columns-menu">
            <button type="button"
                    class="query-library-columns-toggle"
                    data-menu-target="button"
                    data-action="menu#toggle"
                    aria-label="<%= I18n.t('app.workspaces.queries.index.columns_toggle_aria') %>">
              <i class="ri-layout-column-line" aria-hidden="true"></i>
            </button>

            <div class="dropdown query-library-columns-dropdown"
                 data-menu-target="dropdown"
                 data-action="keydown.esc->menu#close"
                 tabindex="0">
              <% User::QUERY_LIBRARY_COLUMNS.each do |column| %>
                <label class="checkbox query-library-columns-dropdown__option">
                  <input type="checkbox"
                         value="<%= column %>"
                         data-query-library-columns-target="checkbox"
                         data-column-key="<%= column %>"
                         data-action="change->query-library-columns#toggleColumn"
                         <%= 'checked' if @visible_columns.include?(column) %>>
                  <div class="check">
                    <i class="ri-check-line"></i>
                  </div>
                  <span class="checkbox-text"><%= I18n.t("app.workspaces.queries.index.columns.#{column}") %></span>
                </label>
              <% end %>
            </div>
          </menu>
        </div>
      </div>

      <% if grouped_view %>
        <div class="query-group-drawers">
          <% if @group_rows.present? %>
            <% @group_rows.each do |row| %>
              <details class="query-group-drawer"
                       data-action="toggle->query-library-groups#syncDrawerToggle"
                       <%= 'open' if row[:open] %>>
                <summary class="query-group-drawer__summary">
                  <div class="query-group-drawer__summary-main">
                    <i class="<%= row[:open] ? 'ri-subtract-line' : 'ri-add-line' %> query-group-drawer__toggle-icon"
                       data-query-library-groups-target="toggleIcon"
                       aria-hidden="true"></i>
                    <h4 class="query-group-drawer__title"><%= row[:group].name %></h4>
                  </div>
                  <% if can_write_queries %>
                    <button type="button"
                            class="link secondary query-group-drawer__delete"
                            data-group-name="<%= row[:group].name %>"
                            data-delete-path="<%= app_workspace_query_group_path(@workspace, row[:group], search: params[:search], view: 'groups') %>"
                            data-action="click->query-library-groups#showDeleteDialog">
                      <%= I18n.t('app.workspaces.queries.index.groups.delete_action') %>
                    </button>
                  <% end %>
                </summary>

                <div class="query-group-drawer__body">
                  <%= render 'queries_table',
                             queries: row[:queries],
                             visible_columns: @visible_columns,
                             workspace: @workspace,
                             table_class: 'queries-table--grouped' %>
                </div>
              </details>
            <% end %>
          <% else %>
            <p class="query-library-groups-empty gray-300">
              <%= I18n.t('app.workspaces.queries.index.groups.empty') %>
            </p>
          <% end %>
        </div>
      <% else %>
        <%= render 'queries_table', queries: @queries, visible_columns: @visible_columns, workspace: @workspace %>
      <% end %>

      <% if can_write_queries %>
        <div class="message query-group-delete-dialog"
             data-query-library-groups-target="dialog"
             data-action="click->query-library-groups#hideDeleteDialogIfBackdrop">
          <div class="body">
            <div class="query-group-delete-dialog__heading">
              <i class="ri-error-warning-line red-500" aria-hidden="true"></i>
              <p class="query-group-delete-dialog__title cream-250"><b><%= I18n.t('app.workspaces.queries.index.groups.dialog.title') %></b></p>
            </div>
            <p class="query-group-delete-dialog__description">
              <%= I18n.t('app.workspaces.queries.index.groups.dialog.description_html', group_name: '<span data-query-library-groups-target="groupName"></span>').html_safe %>
            </p>

            <%= form_with url: '#',
                          method: :delete,
                          class: 'query-group-delete-dialog__actions',
                          html: { data: { query_library_groups_target: 'form' } } do %>
              <%= submit_tag I18n.t('app.workspaces.queries.index.groups.dialog.confirm'), class: 'link primary' %>
              <button type="button" class="link secondary" data-action="query-library-groups#hideDeleteDialog">
                <%= I18n.t('common.actions.cancel') %>
              </button>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</main>
