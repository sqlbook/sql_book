<% creating_new_theme = selected_theme_reference == 'new' %>
<% read_only_theme = selected_theme_entry.read_only? && !creating_new_theme %>
<% active_editor_tab = selected_theme_tab.to_s.presence_in(%w[settings dark light]) || 'settings' %>
<% editor_path = if read_only_theme
                   app_workspace_settings_path(workspace, tab: 'branding', theme: selected_theme_entry.reference_key)
                 elsif creating_new_theme
                   app_workspace_visualization_themes_path(workspace)
                 else
                   app_workspace_visualization_theme_path(workspace, theme_id: selected_theme_entry.id)
                 end %>
<% editor_method = creating_new_theme ? :post : :patch %>
<% preview_payloads = { dark: theme_preview_dark, light: theme_preview_light } %>
<% theme_payloads = { dark: selected_theme_entry.theme_json_dark, light: selected_theme_entry.theme_json_light } %>
<% selected_mode = active_editor_tab == 'light' ? :light : :dark %>
<% selected_mode_attributes = selected_mode == :dark ? theme_editor_attributes_dark : theme_editor_attributes_light %>
<% selected_mode_preview_payload = preview_payloads.fetch(selected_mode) %>
<% selected_mode_theme_json = theme_payloads.fetch(selected_mode).to_h.deep_stringify_keys %>
<% current_name = if creating_new_theme
                    I18n.t('app.workspaces.settings.branding.editor.untitled_name')
                  else
                    selected_theme_entry.name
                  end %>
<% current_default = selected_theme_entry.default? || false %>

<div class="workspace-branding__editor">
  <% settings_fields = capture do %>
    <section class="workspace-branding__section">
      <div class="split">
        <div>
          <label class="label block"><%= I18n.t('app.workspaces.settings.branding.editor.name') %></label>
          <%= text_field_tag :name, current_name, class: 'input block fluid', disabled: read_only_theme, required: true %>
        </div>
        <% unless read_only_theme %>
          <div>
            <label class="label block"><%= I18n.t('app.workspaces.settings.branding.editor.default') %></label>
            <div class="select">
              <%= select_tag :default,
                             options_for_select([[I18n.t('common.states.no'), false], [I18n.t('common.states.yes'), true]], current_default) %>
              <i class="ri-arrow-drop-down-line"></i>
            </div>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>

  <% mode_fields = capture do %>
    <% if selected_mode_preview_payload.present? %>
      <section class="workspace-branding__preview workspace-branding__preview--single">
        <div class="workspace-branding__preview-header">
          <h4 class="cream-250"><%= I18n.t('app.workspaces.settings.branding.editor.preview_title') %></h4>
          <p class="gray-300"><%= I18n.t('app.workspaces.settings.branding.editor.preview_description') %></p>
        </div>

        <article class="workspace-branding__chart-card">
          <p class="workspace-branding__chart-label"><%= I18n.t("app.workspaces.settings.branding.editor.#{selected_mode}_title") %></p>
          <div class="workspace-branding__palette">
            <% selected_mode_preview_payload.fetch(:palette, []).each do |color| %>
              <span class="workspace-branding__swatch" style="background-color: <%= color %>;" title="<%= color %>"></span>
            <% end %>
          </div>
          <div class="workspace-branding__chart-grid">
            <% selected_mode_preview_payload.fetch(:charts, {}).each do |chart_type, option| %>
              <article class="workspace-branding__chart-card">
                <p class="workspace-branding__chart-label">
                  <%= I18n.t(Visualizations::ChartRegistry.fetch(chart_type)[:label_key]) %>
                </p>
                <div
                  class="workspace-branding__chart-preview"
                  data-controller="echarts-visualization"
                  data-echarts-visualization-mode-value="<%= selected_mode %>"
                  data-echarts-visualization-dark-option-value="<%= option.to_json %>"
                  data-echarts-visualization-light-option-value="<%= option.to_json %>"
                  data-echarts-visualization-dark-theme-value="<%= selected_mode_theme_json.to_json %>"
                  data-echarts-visualization-light-theme-value="<%= selected_mode_theme_json.to_json %>"></div>
              </article>
            <% end %>
          </div>
        </article>
      </section>
    <% end %>

    <section class="workspace-branding__section">
      <%= render "app/workspaces/settings/branding_mode_fields",
                 mode: selected_mode,
                 attributes: selected_mode_attributes,
                 read_only_theme: %>
    </section>
  <% end %>

  <% if read_only_theme %>
    <div class="workspace-branding__form">
      <%= active_editor_tab == 'settings' ? settings_fields : mode_fields %>
      <div class="workspace-branding__actions">
        <%= button_to I18n.t('app.workspaces.settings.branding.actions.duplicate'),
                      app_duplicate_workspace_visualization_theme_path(workspace),
                      params: { reference: selected_theme_entry.reference_key },
                      method: :post,
                      class: 'link primary' %>
      </div>
    </div>
  <% else %>
    <%= form_with url: editor_path, method: editor_method, class: "workspace-branding__form" do %>
      <% if active_editor_tab == 'settings' %>
        <%= settings_fields %>
        <%= hidden_field_tag :raw_json_dark, theme_editor_attributes_dark[:raw_json] %>
        <%= hidden_field_tag :raw_json_light, theme_editor_attributes_light[:raw_json] %>
      <% else %>
        <%= hidden_field_tag :name, current_name %>
        <%= hidden_field_tag :default, current_default %>
        <% if selected_mode == :dark %>
          <%= hidden_field_tag :raw_json_light, theme_editor_attributes_light[:raw_json] %>
        <% else %>
          <%= hidden_field_tag :raw_json_dark, theme_editor_attributes_dark[:raw_json] %>
        <% end %>
        <%= mode_fields %>
      <% end %>

      <div class="workspace-branding__actions">
        <%= submit_tag I18n.t('common.actions.save_changes'), class: 'link primary' %>
      </div>
    <% end %>
  <% end %>
</div>
