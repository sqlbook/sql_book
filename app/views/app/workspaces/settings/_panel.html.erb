<div class="tabs">
    <%= render "shared/tabs/nav_item", tab: "general", name: I18n.t('app.workspaces.settings.tabs.general'), icon_class: "ri-global-line", default_selected: true %>
    <%= render "shared/tabs/nav_item", tab: "team", name: I18n.t('app.workspaces.settings.tabs.team'), icon_class: "ri-fire-line" %>
    <%= render "shared/tabs/nav_item", tab: "branding", name: I18n.t('app.workspaces.settings.tabs.branding'), icon_class: "ri-palette-line" %>
    <%= render "shared/tabs/nav_item", tab: "subscription", name: I18n.t('app.workspaces.settings.tabs.subscription'), icon_class: "ri-fire-line" %>
  <% if can_delete_workspace %>
    <%= render "shared/tabs/nav_item", tab: "delete", name: I18n.t('common.actions.delete_workspace_label'), icon_class: "ri-delete-bin-line" %>
  <% end %>
</div>

<% if active_tab?(tab: "general", default_selected: true) %>
  <div data-controller="form" data-form-require-change-value="true">
    <%= form_with url: app_workspace_settings_path(@workspace), method: :patch, class: "workspace-update-form", html: { "data-form-target": "form" } do |form| %>
      <%= form.label :name, I18n.t('app.workspaces.settings.general.workspace_name_label'), class: "label block" %>
      <%= form.text_field :name, class: "input block fluid", value: @workspace.name, required: true %>
      <%= form.submit I18n.t('common.actions.save_changes'), class: "link primary", "data-form-target": "submit", disabled: true %>
    <% end %>
  </div>
<% end %>

<% if active_tab?(tab: "team") %>
  <%= turbo_stream_from RealtimeUpdatesService.workspace_members_stream(workspace: @workspace) %>
  <p><%= I18n.t('app.workspaces.settings.team.description') %></p>
  <div class="members-table" data-controller="table">
    <table class="collapsible team-members-table">
      <tr>
        <th class="name">
          <span class="truncate-text" data-tooltip-text="<%= I18n.t('app.workspaces.settings.team.table.name') %>"><%= I18n.t('app.workspaces.settings.team.table.name') %></span>
        </th>
        <th class="role">
          <span class="truncate-text" data-tooltip-text="<%= I18n.t('app.workspaces.settings.team.table.role') %>"><%= I18n.t('app.workspaces.settings.team.table.role') %></span>
        </th>
        <th class="status">
          <span class="truncate-text" data-tooltip-text="<%= I18n.t('app.workspaces.settings.team.table.status') %>"><%= I18n.t('app.workspaces.settings.team.table.status') %></span>
        </th>
        <th class="actions">
          <span class="truncate-text" data-tooltip-text="<%= I18n.t('app.workspaces.settings.team.table.actions') %>"><%= I18n.t('app.workspaces.settings.team.table.actions') %></span>
        </th>
      </tr>
      <% @workspace.members.each do |member| %>
        <% can_edit_member = can_manage_members && current_role < member.role %>
        <tr>
          <td class="name">
            <% member_name = member.user.full_name %>
            <% you_label = member.user_id == @current_user.id ? " #{I18n.t('app.workspaces.settings.team.table.you')}" : '' %>
            <span class="truncate-text" data-tooltip-text="<%= "#{member_name}#{you_label}" %>">
              <%= member_name %>
              <% if member.user_id == @current_user.id %>
                <span class="you-indicator text-small gray-300"><%= I18n.t('app.workspaces.settings.team.table.you') %></span>
              <% end %>
            </span>
          </td>
          <td class="role">
            <% if can_edit_member %>
              <%= form_with url: app_workspace_member_path(@workspace, member), method: :patch, class: "member-role-form" do |form| %>
                <div class="select member-role-select">
                  <%= form.select :role,
                                  options_for_select(editable_role_options, member.role),
                                  {},
                                  { "aria-label": I18n.t('app.workspaces.settings.team.aria.change_role', name: member.user.full_name), onchange: "this.form.requestSubmit();" } %>
                  <i class="ri-arrow-drop-down-line"></i>
                </div>
              <% end %>
            <% else %>
              <span class="truncate-text" data-tooltip-text="<%= member.role_name %>"><%= member.role_name %></span>
            <% end %>
          </td>
          <td class="status">
            <span class="truncate-text" data-tooltip-text="<%= member.status_name %>"><%= member.status_name %></span>
          </td>
          <td class="actions">
            <% if can_edit_member %>
              <div class="actions-inline">
                <% if member.pending? %>
                  <%= link_to I18n.t('app.workspaces.settings.team.actions.resend_invitation'), resend_app_workspace_member_path(@workspace, member), class: "link secondary", data: { turbo_method: :post }, "aria-label": I18n.t('app.workspaces.settings.team.aria.resend_invitation', name: member.user.full_name) %>
                  <%= link_to I18n.t('common.actions.delete'), app_workspace_member_path(@workspace, member), class: "link secondary", data: { turbo_method: :delete }, "aria-label": I18n.t('app.workspaces.settings.team.aria.delete_invitation', name: member.user.full_name) %>
                <% else %>
                  <%= link_to I18n.t('common.actions.delete'), app_workspace_member_path(@workspace, member), class: "link secondary", data: { turbo_method: :delete }, "aria-label": I18n.t('app.workspaces.settings.team.aria.remove_member', name: member.user.full_name) %>
                <% end %>
              </div>
            <% end %>
          </td>
        </tr>
      <% end %>
    </table>
  </div>

  <% if can_manage_members %>
    <div data-controller="member-invite">
      <button class="link secondary invite show" type="button" data-member-invite-target="button" data-action="member-invite#show">
        <i class="ri-add-line"></i>
        <span><%= I18n.t('app.workspaces.settings.team.actions.invite_member') %></span>
      </button>

      <div data-controller="form">
        <%= form_with url: app_workspace_members_path(@workspace), method: :post, class: "invite-team-member-form", html: { "data-form-target": "form", "data-member-invite-target": "form" } do |form| %>
          <div class="split">
            <div>
              <%= form.label :first_name, I18n.t('app.workspaces.settings.team.form.first_name_label'), class: "label block" %>
              <%= form.text_field :first_name, class: "input block fluid", placeholder: I18n.t('app.workspaces.settings.team.form.first_name_placeholder'), required: true %>
            </div>
            <div>
              <%= form.label :last_name, I18n.t('app.workspaces.settings.team.form.last_name_label'), class: "label block" %>
              <%= form.text_field :last_name, class: "input block fluid", placeholder: I18n.t('app.workspaces.settings.team.form.last_name_placeholder'), required: true %>
            </div>
          </div>
          <div class="split">
            <div>
              <%= form.label :email, I18n.t('app.workspaces.settings.team.form.email_label'), class: "label block" %>
              <%= form.email_field :email, class: "input block fluid", autocomplete: "email", placeholder: I18n.t('app.workspaces.settings.team.form.email_placeholder'), required: true %>
            </div>
            <div>
              <%= form.label :role, I18n.t('app.workspaces.settings.team.form.role_label'), class: "label block" %>
              <div class="select">
                <%= form.select :role, options_for_select(editable_role_options), {} %>
                <i class="ri-arrow-drop-down-line"></i>
              </div>
            </div>
          </div>
          <div class="actions">
            <%= form.submit I18n.t('app.workspaces.settings.team.form.send_invitation'), class: "link primary", "data-form-target": "submit" %>
            <button type="button" class="link secondary" data-action="member-invite#hide">
              <%= I18n.t('common.actions.cancel') %>
            </button>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>

<% if active_tab?(tab: "branding") %>
  <%= render "app/workspaces/settings/branding",
             workspace: @workspace,
             theme_library: @theme_library,
             selected_theme_entry: @selected_theme_entry,
             selected_theme_reference: @selected_theme_reference,
             selected_theme_tab: @selected_theme_tab,
             theme_editor_attributes_dark: @theme_editor_attributes_dark,
             theme_editor_attributes_light: @theme_editor_attributes_light %>
<% end %>

<% if active_tab?(tab: "subscription") %>
  -
<% end %>

<% if can_delete_workspace && active_tab?(tab: "delete") %>
  <div class="delete-workspace">
    <p class="cream-250"><%= I18n.t('app.workspaces.settings.delete.title') %></p>
    <ul>
      <li><%= I18n.t('app.workspaces.settings.delete.guidance.delete_data') %></li>
      <li><%= I18n.t('app.workspaces.settings.delete.guidance.irreversible') %></li>
    </ul>

    <% if params[:confirm_delete] %>
      <div class="message">
        <i class="ri-error-warning-line ri-lg red-500"></i>
        <div class="body">
          <p class="title cream-250"><b><%= I18n.t('app.workspaces.settings.delete.confirmation.title') %></b></p>
          <p><%= I18n.t('app.workspaces.settings.delete.confirmation.body') %></p>
          <div class="actions">
            <%= link_to I18n.t('common.actions.delete_workspace'), app_workspace_path(@workspace), class: "link primary", data: { turbo_method: :delete }, "aria-label": I18n.t('app.workspaces.settings.delete.confirmation.confirm_aria') %>
            <%= link_to I18n.t('common.actions.cancel'), add_params(confirm_delete: nil), class: "link secondary", "aria-label": I18n.t('app.workspaces.settings.delete.confirmation.cancel_aria') %>
          </div>
        </div>
      </div>
    <% else %>
      <%= link_to I18n.t('common.actions.delete_workspace'), add_params(confirm_delete: 1), class: "link primary", "aria-label": I18n.t('app.workspaces.settings.delete.trigger_aria') %>
    <% end %>
  </div>
<% end %>
