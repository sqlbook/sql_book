<main>
  <div class="page-header">
    <h1>Workspaces</h1>
    <%= link_to new_app_workspace_path, class: "link secondary create-workspace", "data-shortcut": "N", "aria-label": "Create a new workspace" do %>
      <i class="ri-add-line red-500"></i>
      <span><%= I18n.t('common.actions.create_new') %></span>
    <% end %>
  </div>

  <%= render "shared/flash" %>

  <div class="workspaces container lg" data-controller="cards">
    <% @workspaces.each do |workspace| %>
      <%= render "shared/workspace_card", workspace: %>
    <% end %>
  </div>
</main>
